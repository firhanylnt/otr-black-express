{
  "name": "otr-black-backend",
  "version": "1.0.0",
  "description": "OTR API for otr-new-version-black - Express, R2, Vercel",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma generate && tsc && node --watch dist/index.js",
    "start": "node dist/index.js",
    "build": "prisma generate && tsc",
    "vercel-build": "npm run build",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "prisma": "^6.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
