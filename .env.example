# Server
NODE_ENV=development
PORT=3005
API_PREFIX=/api

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3002,http://localhost:3000

# Frontend URL (for redirects, etc.)
FRONTEND_URL=http://localhost:3000

# PostgreSQL (required). Example: Supabase connection string
DATABASE_URL=postgresql://user:password@host:5432/postgres

# JWT (required)
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# Cloudflare R2 (optional; required for /upload/image and /upload/audio)
